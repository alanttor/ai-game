[
  {
    "title": "Emoji 跳跃小游戏",
    "desc": "玩家控制一个emoji角色跳过障碍物。",
    "icon": "🐇",
    "color": "#ffd700",
    "tags": [
      "自定义"
    ],
    "htmlContent": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Emoji跳跃小游戏</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Arial Rounded MT Bold', 'Arial', sans-serif;\n        }\n        \n        body {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            min-height: 100vh;\n            background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);\n            color: white;\n            padding: 20px;\n            overflow-x: hidden;\n        }\n        \n        .container {\n            max-width: 800px;\n            width: 100%;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n        \n        header {\n            text-align: center;\n            margin-bottom: 20px;\n            width: 100%;\n        }\n        \n        h1 {\n            font-size: 2.8rem;\n            margin-bottom: 10px;\n            text-shadow: 3px 3px 0 rgba(0, 0, 0, 0.2);\n            background: linear-gradient(to right, #ff8a00, #e52e71);\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n        }\n        \n        .subtitle {\n            font-size: 1.2rem;\n            opacity: 0.9;\n            margin-bottom: 25px;\n        }\n        \n        .game-container {\n            position: relative;\n            width: 100%;\n            max-width: 700px;\n            margin-bottom: 25px;\n        }\n        \n        canvas {\n            display: block;\n            background-color: #0f1b2f;\n            border-radius: 12px;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);\n            border: 4px solid #2a3f6e;\n        }\n        \n        .score-board {\n            display: flex;\n            justify-content: space-between;\n            width: 100%;\n            max-width: 700px;\n            margin-bottom: 20px;\n            background-color: rgba(255, 255, 255, 0.1);\n            padding: 15px 25px;\n            border-radius: 12px;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);\n            border: 2px solid rgba(255, 255, 255, 0.15);\n        }\n        \n        .score-item {\n            text-align: center;\n        }\n        \n        .score-label {\n            font-size: 1rem;\n            opacity: 0.8;\n            margin-bottom: 5px;\n        }\n        \n        .score-value {\n            font-size: 2.2rem;\n            font-weight: bold;\n        }\n        \n        .controls {\n            display: flex;\n            flex-wrap: wrap;\n            justify-content: center;\n            gap: 15px;\n            margin-bottom: 25px;\n            width: 100%;\n            max-width: 700px;\n        }\n        \n        button {\n            padding: 14px 28px;\n            font-size: 1.1rem;\n            font-weight: bold;\n            border: none;\n            border-radius: 50px;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            gap: 10px;\n        }\n        \n        .jump-btn {\n            background: linear-gradient(to right, #00b09b, #96c93d);\n            color: white;\n            flex: 1;\n            min-width: 180px;\n        }\n        \n        .start-btn {\n            background: linear-gradient(to right, #ff416c, #ff4b2b);\n            color: white;\n            flex: 1;\n            min-width: 180px;\n        }\n        \n        .reset-btn {\n            background: linear-gradient(to right, #8e2de2, #4a00e0);\n            color: white;\n            flex: 1;\n            min-width: 180px;\n        }\n        \n        button:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);\n        }\n        \n        button:active {\n            transform: translateY(0);\n        }\n        \n        button:disabled {\n            opacity: 0.6;\n            cursor: not-allowed;\n            transform: none;\n        }\n        \n        .instructions {\n            background-color: rgba(255, 255, 255, 0.1);\n            padding: 20px;\n            border-radius: 12px;\n            margin-top: 15px;\n            width: 100%;\n            max-width: 700px;\n            border: 2px solid rgba(255, 255, 255, 0.15);\n        }\n        \n        .instructions h3 {\n            font-size: 1.3rem;\n            margin-bottom: 12px;\n            color: #ffd166;\n        }\n        \n        .instructions ul {\n            padding-left: 20px;\n        }\n        \n        .instructions li {\n            margin-bottom: 8px;\n            line-height: 1.5;\n        }\n        \n        .emoji-selector {\n            display: flex;\n            justify-content: center;\n            gap: 15px;\n            margin-top: 15px;\n            margin-bottom: 25px;\n            flex-wrap: wrap;\n        }\n        \n        .emoji-option {\n            font-size: 2.5rem;\n            cursor: pointer;\n            padding: 10px;\n            border-radius: 10px;\n            transition: all 0.3s;\n            background-color: rgba(255, 255, 255, 0.1);\n        }\n        \n        .emoji-option:hover {\n            transform: scale(1.2);\n            background-color: rgba(255, 255, 255, 0.2);\n        }\n        \n        .emoji-option.selected {\n            transform: scale(1.2);\n            background-color: rgba(255, 255, 255, 0.3);\n            box-shadow: 0 0 15px rgba(255, 255, 255, 0.5);\n        }\n        \n        .key-hint {\n            font-size: 0.9rem;\n            opacity: 0.7;\n            margin-top: 5px;\n        }\n        \n        .game-over {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background-color: rgba(0, 0, 0, 0.85);\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            border-radius: 12px;\n            z-index: 10;\n            display: none;\n        }\n        \n        .game-over h2 {\n            font-size: 3.5rem;\n            color: #ff416c;\n            margin-bottom: 20px;\n            text-shadow: 0 0 10px rgba(255, 65, 108, 0.7);\n        }\n        \n        .game-over p {\n            font-size: 1.8rem;\n            margin-bottom: 30px;\n        }\n        \n        .mobile-controls {\n            display: none;\n            justify-content: center;\n            gap: 30px;\n            margin-top: 20px;\n            width: 100%;\n        }\n        \n        .mobile-btn {\n            width: 80px;\n            height: 80px;\n            border-radius: 50%;\n            background-color: rgba(255, 255, 255, 0.2);\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 2rem;\n            cursor: pointer;\n            user-select: none;\n            border: 3px solid rgba(255, 255, 255, 0.4);\n        }\n        \n        @media (max-width: 768px) {\n            .mobile-controls {\n                display: flex;\n            }\n            \n            h1 {\n                font-size: 2.2rem;\n            }\n            \n            .score-value {\n                font-size: 1.8rem;\n            }\n            \n            button {\n                padding: 12px 20px;\n                font-size: 1rem;\n            }\n            \n            .controls {\n                flex-direction: column;\n                align-items: center;\n            }\n            \n            button {\n                width: 100%;\n                max-width: 300px;\n            }\n        }\n        \n        footer {\n            margin-top: 30px;\n            text-align: center;\n            font-size: 0.9rem;\n            opacity: 0.8;\n            width: 100%;\n            max-width: 700px;\n            padding-top: 15px;\n            border-top: 1px solid rgba(255, 255, 255, 0.2);\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>🚀 Emoji 跳跃小游戏 🎮</h1>\n            <p class=\"subtitle\">控制你的emoji角色跳跃避开障碍物，尽可能获得高分！</p>\n        </header>\n        \n        <div class=\"score-board\">\n            <div class=\"score-item\">\n                <div class=\"score-label\">当前分数</div>\n                <div id=\"score\" class=\"score-value\">0</div>\n            </div>\n            <div class=\"score-item\">\n                <div class=\"score-label\">最高分</div>\n                <div id=\"high-score\" class=\"score-value\">0</div>\n            </div>\n            <div class=\"score-item\">\n                <div class=\"score-label\">速度</div>\n                <div id=\"speed\" class=\"score-value\">1.0x</div>\n            </div>\n        </div>\n        \n        <div class=\"game-container\">\n            <canvas id=\"gameCanvas\" width=\"700\" height=\"400\"></canvas>\n            \n            <div id=\"gameOver\" class=\"game-over\">\n                <h2>游戏结束 😢</h2>\n                <p>得分: <span id=\"final-score\">0</span></p>\n                <button class=\"start-btn\" id=\"restart-btn\">🔄 重新开始</button>\n            </div>\n        </div>\n        \n        <div class=\"emoji-selector\">\n            <div class=\"emoji-option selected\" data-emoji=\"🚀\">🚀</div>\n            <div class=\"emoji-option\" data-emoji=\"🐱\">🐱</div>\n            <div class=\"emoji-option\" data-emoji=\"🐶\">🐶</div>\n            <div class=\"emoji-option\" data-emoji=\"🦊\">🦊</div>\n            <div class=\"emoji-option\" data-emoji=\"🐵\">🐵</div>\n            <div class=\"emoji-option\" data-emoji=\"🦄\">🦄</div>\n        </div>\n        \n        <div class=\"controls\">\n            <button class=\"jump-btn\" id=\"jump-btn\">\n                <span>🦘</span> 跳跃 (空格键)\n                <div class=\"key-hint\">或点击这里跳跃</div>\n            </button>\n            <button class=\"start-btn\" id=\"start-btn\">\n                <span>▶️</span> 开始游戏\n            </button>\n            <button class=\"reset-btn\" id=\"reset-btn\">\n                <span>🔄</span> 重置游戏\n            </button>\n        </div>\n        \n        <div class=\"mobile-controls\">\n            <div class=\"mobile-btn\" id=\"mobile-jump\">🦘</div>\n        </div>\n        \n        <div class=\"instructions\">\n            <h3>📋 游戏说明</h3>\n            <ul>\n                <li>点击 <strong>开始游戏</strong> 按钮或按 <strong>空格键</strong> 开始游戏</li>\n                <li>控制你的emoji角色跳跃避开障碍物 🚧</li>\n                <li>每跳过一个障碍物得 <strong>10分</strong></li>\n                <li>游戏速度会随着分数增加而逐渐加快 ⚡</li>\n                <li>碰到障碍物或掉到地面游戏结束 💥</li>\n                <li>点击上方emoji可以切换角色形象</li>\n                <li>在手机上可以点击跳跃按钮或屏幕任意位置跳跃</li>\n            </ul>\n        </div>\n        \n        <footer>\n            <p>🎮 使用HTML5 Canvas开发的Emoji跳跃小游戏 | 单文件实现 | 2023</p>\n        </footer>\n    </div>\n\n    <script>\n        // 游戏变量\n        const canvas = document.getElementById('gameCanvas');\n        const ctx = canvas.getContext('2d');\n        const scoreElement = document.getElementById('score');\n        const highScoreElement = document.getElementById('high-score');\n        const speedElement = document.getElementById('speed');\n        const startBtn = document.getElementById('start-btn');\n        const jumpBtn = document.getElementById('jump-btn');\n        const resetBtn = document.getElementById('reset-btn');\n        const restartBtn = document.getElementById('restart-btn');\n        const gameOverScreen = document.getElementById('gameOver');\n        const finalScoreElement = document.getElementById('final-score');\n        const mobileJumpBtn = document.getElementById('mobile-jump');\n        const emojiOptions = document.querySelectorAll('.emoji-option');\n        \n        // 游戏状态\n        let gameRunning = false;\n        let score = 0;\n        let highScore = localStorage.getItem('emojiJumpHighScore') || 0;\n        let gameSpeed = 1.0;\n        let playerEmoji = '🚀';\n        \n        // 初始化最高分显示\n        highScoreElement.textContent = highScore;\n        \n        // 玩家角色\n        const player = {\n            x: 100,\n            y: canvas.height - 100,\n            width: 60,\n            height: 60,\n            velocityY: 0,\n            gravity: 0.8,\n            jumpPower: -16,\n            isJumping: false,\n            \n            draw() {\n                // 绘制阴影\n                ctx.shadowColor = 'rgba(0, 0, 0, 0.5)';\n                ctx.shadowBlur = 10;\n                ctx.shadowOffsetX = 0;\n                ctx.shadowOffsetY = 5;\n                \n                // 绘制emoji\n                ctx.font = `${this.height}px Arial`;\n                ctx.textAlign = 'center';\n                ctx.textBaseline = 'middle';\n                ctx.fillText(playerEmoji, this.x + this.width/2, this.y + this.height/2);\n                \n                // 重置阴影\n                ctx.shadowColor = 'transparent';\n                ctx.shadowBlur = 0;\n            },\n            \n            jump() {\n                if (!this.isJumping) {\n                    this.velocityY = this.jumpPower;\n                    this.isJumping = true;\n                    \n                    // 跳跃音效（使用Web Audio API生成简单音效）\n                    playJumpSound();\n                }\n            },\n            \n            update() {\n                // 应用重力\n                this.velocityY += this.gravity;\n                this.y += this.velocityY;\n                \n                // 地面碰撞检测\n                if (this.y >= canvas.height - 100) {\n                    this.y = canvas.height - 100;\n                    this.velocityY = 0;\n                    this.isJumping = false;\n                }\n                \n                // 天花板碰撞检测（防止跳出画布）\n                if (this.y < 0) {\n                    this.y = 0;\n                    this.velocityY = 0;\n                }\n            },\n            \n            reset() {\n                this.y = canvas.height - 100;\n                this.velocityY = 0;\n                this.isJumping = false;\n            }\n        };\n        \n        // 障碍物\n        let obstacles = [];\n        \n        class Obstacle {\n            constructor() {\n                this.width = 30;\n                this.height = Math.random() * 50 + 30;\n                this.x = canvas.width;\n                this.y = canvas.height - 100 - this.height;\n                this.speed = 5 * gameSpeed;\n                this.color = this.getRandomColor();\n                this.emoji = this.getRandomObstacleEmoji();\n            }\n            \n            getRandomColor() {\n                const colors = ['#FF5252', '#FF4081', '#E040FB', '#7C4DFF', '#536DFE', '#448AFF', '#40C4FF', '#18FFFF', '#64FFDA', '#69F0AE'];\n                return colors[Math.floor(Math.random() * colors.length)];\n            }\n            \n            getRandomObstacleEmoji() {\n                const obstacleEmojis = ['🚧', '🪨', '🌵', '🪵', '🛑', '🔥', '💣', '⚠️', '🗿', '🧱'];\n                return obstacleEmojis[Math.floor(Math.random() * obstacleEmojis.length)];\n            }\n            \n            draw() {\n                // 绘制障碍物矩形\n                ctx.fillStyle = this.color;\n                ctx.fillRect(this.x, this.y, this.width, this.height);\n                \n                // 绘制障碍物顶部的emoji\n                ctx.font = '30px Arial';\n                ctx.textAlign = 'center';\n                ctx.textBaseline = 'middle';\n                ctx.fillText(this.emoji, this.x + this.width/2, this.y - 15);\n                \n                // 绘制障碍物阴影\n                ctx.shadowColor = 'rgba(0, 0, 0, 0.5)';\n                ctx.shadowBlur = 5;\n                ctx.shadowOffsetX = 2;\n                ctx.shadowOffsetY = 2;\n                ctx.fillRect(this.x, this.y, this.width, this.height);\n                ctx.shadowColor = 'transparent';\n                ctx.shadowBlur = 0;\n                ctx.shadowOffsetX = 0;\n                ctx.shadowOffsetY = 0;\n            }\n            \n            update() {\n                this.x -= this.speed;\n                this.speed = 5 * gameSpeed;\n            }\n            \n            isOffScreen() {\n                return this.x + this.width < 0;\n            }\n            \n            collidesWith(player) {\n                return (\n                    player.x < this.x + this.width &&\n                    player.x + player.width > this.x &&\n                    player.y < this.y + this.height &&\n                    player.y + player.height > this.y\n                );\n            }\n        }\n        \n        // 地面\n        const ground = {\n            height: 100,\n            draw() {\n                // 绘制地面\n                ctx.fillStyle = '#3e2723';\n                ctx.fillRect(0, canvas.height - this.height, canvas.width, this.height);\n                \n                // 绘制地面纹理\n                ctx.fillStyle = '#5d4037';\n                for (let i = 0; i < canvas.width; i += 20) {\n                    ctx.fillRect(i, canvas.height - this.height, 10, 5);\n                }\n                \n                // 绘制草地\n                ctx.fillStyle = '#4caf50';\n                ctx.fillRect(0, canvas.height - this.height, canvas.width, 10);\n                \n                // 绘制草叶\n                ctx.fillStyle = '#81c784';\n                for (let i = 0; i < canvas.width; i += 15) {\n                    const height = Math.random() * 15 + 5;\n                    ctx.fillRect(i, canvas.height - this.height - height, 2, height);\n                }\n            }\n        };\n        \n        // 背景\n        const background = {\n            stars: [],\n            \n            init() {\n                this.stars = [];\n                for (let i = 0; i < 50; i++) {\n                    this.stars.push({\n                        x: Math.random() * canvas.width,\n                        y: Math.random() * (canvas.height - ground.height),\n                        size: Math.random() * 2 + 1,\n                        speed: Math.random() * 0.5 + 0.2\n                    });\n                }\n            },\n            \n            draw() {\n                // 绘制渐变背景\n                const gradient = ctx.createLinearGradient(0, 0, 0, canvas.height);\n                gradient.addColorStop(0, '#0c2461');\n                gradient.addColorStop(1, '#1e3799');\n                ctx.fillStyle = gradient;\n                ctx.fillRect(0, 0, canvas.width, canvas.height);\n                \n                // 绘制星星\n                ctx.fillStyle = 'white';\n                this.stars.forEach(star => {\n                    ctx.beginPath();\n                    ctx.arc(star.x, star.y, star.size, 0, Math.PI * 2);\n                    ctx.fill();\n                });\n                \n                // 绘制云朵\n                ctx.fillStyle = 'rgba(255, 255, 255, 0.2)';\n                ctx.beginPath();\n                ctx.ellipse(150, 80, 40, 20, 0, 0, Math.PI * 2);\n                ctx.ellipse(190, 70, 30, 25, 0, 0, Math.PI * 2);\n                ctx.ellipse(230, 80, 40, 20, 0, 0, Math.PI * 2);\n                ctx.fill();\n                \n                ctx.beginPath();\n                ctx.ellipse(500, 120, 50, 25, 0, 0, Math.PI * 2);\n                ctx.ellipse(540, 110, 40, 30, 0, 0, Math.PI * 2);\n                ctx.ellipse(580, 120, 50, 25, 0, 0, Math.PI * 2);\n                ctx.fill();\n            },\n            \n            update() {\n                this.stars.forEach(star => {\n                    star.x -= star.speed * gameSpeed;\n                    if (star.x < 0) {\n                        star.x = canvas.width;\n                        star.y = Math.random() * (canvas.height - ground.height);\n                    }\n                });\n            }\n        };\n        \n        // 初始化背景\n        background.init();\n        \n        // 游戏函数\n        function startGame() {\n            if (gameRunning) return;\n            \n            gameRunning = true;\n            score = 0;\n            gameSpeed = 1.0;\n            obstacles = [];\n            player.reset();\n            \n            scoreElement.textContent = score;\n            speedElement.textContent = gameSpeed.toFixed(1) + 'x';\n            gameOverScreen.style.display = 'none';\n            \n            startBtn.disabled = true;\n            startBtn.innerHTML = '<span>⏸️</span> 游戏中...';\n            \n            // 生成第一个障碍物\n            setTimeout(() => {\n                obstacles.push(new Obstacle());\n            }, 1000);\n            \n            gameLoop();\n        }\n        \n        function resetGame() {\n            gameRunning = false;\n            score = 0;\n            gameSpeed = 1.0;\n            obstacles = [];\n            player.reset();\n            \n            scoreElement.textContent = score;\n            speedElement.textContent = gameSpeed.toFixed(1) + 'x';\n            gameOverScreen.style.display = 'none';\n            \n            startBtn.disabled = false;\n            startBtn.innerHTML = '<span>▶️</span> 开始游戏';\n            \n            // 重新绘制静态画面\n            draw();\n        }\n        \n        function endGame() {\n            gameRunning = false;\n            \n            // 更新最高分\n            if (score > highScore) {\n                highScore = score;\n                localStorage.setItem('emojiJumpHighScore', highScore);\n                highScoreElement.textContent = highScore;\n            }\n            \n            // 显示游戏结束画面\n            gameOverScreen.style.display = 'flex';\n            finalScoreElement.textContent = score;\n            \n            startBtn.disabled = false;\n            startBtn.innerHTML = '<span>▶️</span> 重新开始';\n            \n            // 播放游戏结束音效\n            playGameOverSound();\n        }\n        \n        function gameLoop() {\n            if (!gameRunning) return;\n            \n            // 清空画布\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n            \n            // 更新和绘制背景\n            background.update();\n            background.draw();\n            \n            // 更新和绘制地面\n            ground.draw();\n            \n            // 更新和绘制玩家\n            player.update();\n            player.draw();\n            \n            // 更新和绘制障碍物\n            for (let i = obstacles.length - 1; i >= 0; i--) {\n                obstacles[i].update();\n                obstacles[i].draw();\n                \n                // 检测碰撞\n                if (obstacles[i].collidesWith(player)) {\n                    endGame();\n                    return;\n                }\n                \n                // 检测是否越过障碍物\n                if (!obstacles[i].passed && obstacles[i].x + obstacles[i].width < player.x) {\n                    obstacles[i].passed = true;\n                    score += 10;\n                    scoreElement.textContent = score;\n                    \n                    // 每得100分增加游戏速度\n                    if (score % 100 === 0) {\n                        gameSpeed += 0.1;\n                        speedElement.textContent = gameSpeed.toFixed(1) + 'x';\n                    }\n                    \n                    // 播放得分音效\n                    playScoreSound();\n                }\n                \n                // 移除屏幕外的障碍物\n                if (obstacles[i].isOffScreen()) {\n                    obstacles.splice(i, 1);\n                }\n            }\n            \n            // 随机生成新障碍物\n            if (obstacles.length < 3 && Math.random() < 0.02) {\n                obstacles.push(new Obstacle());\n            }\n            \n            // 继续游戏循环\n            requestAnimationFrame(gameLoop);\n        }\n        \n        function draw() {\n            // 绘制静态画面\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n            \n            background.draw();\n            ground.draw();\n            player.draw();\n            \n            // 绘制初始障碍物示例\n            ctx.fillStyle = '#FF5252';\n            ctx.fillRect(500, canvas.height - 150, 30, 50);\n            ctx.font = '30px Arial';\n            ctx.textAlign = 'center';\n            ctx.textBaseline = 'middle';\n            ctx.fillText('🚧', 515, canvas.height - 175);\n        }\n        \n        // 初始化绘制\n        draw();\n        \n        // 音频函数\n        function playJumpSound() {\n            try {\n                const audioContext = new (window.AudioContext || window.webkitAudioContext)();\n                const oscillator = audioContext.createOscillator();\n                const gainNode = audioContext.createGain();\n                \n                oscillator.connect(gainNode);\n                gainNode.connect(audioContext.destination);\n                \n                oscillator.frequency.setValueAtTime(523.25, audioContext.currentTime); // C5\n                oscillator.frequency.exponentialRampToValueAtTime(659.25, audioContext.currentTime + 0.2); // E5\n                \n                gainNode.gain.setValueAtTime(0.3, audioContext.currentTime);\n                gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.3);\n                \n                oscillator.start(audioContext.currentTime);\n                oscillator.stop(audioContext.currentTime + 0.3);\n            } catch (e) {\n                console.log(\"音频上下文不支持或已暂停\");\n            }\n        }\n        \n        function playScoreSound() {\n            try {\n                const audioContext = new (window.AudioContext || window.webkitAudioContext)();\n                const oscillator = audioContext.createOscillator();\n                const gainNode = audioContext.createGain();\n                \n                oscillator.connect(gainNode);\n                gainNode.connect(audioContext.destination);\n                \n                oscillator.frequency.setValueAtTime(659.25, audioContext.currentTime); // E5\n                oscillator.frequency.exponentialRampToValueAtTime(783.99, audioContext.currentTime + 0.1); // G5\n                \n                gainNode.gain.setValueAtTime(0.3, audioContext.currentTime);\n                gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.2);\n                \n                oscillator.start(audioContext.currentTime);\n                oscillator.stop(audioContext.currentTime + 0.2);\n            } catch (e) {\n                console.log(\"音频上下文不支持或已暂停\");\n            }\n        }\n        \n        function playGameOverSound() {\n            try {\n                const audioContext = new (window.AudioContext || window.webkitAudioContext)();\n                const oscillator = audioContext.createOscillator();\n                const gainNode = audioContext.createGain();\n                \n                oscillator.connect(gainNode);\n                gainNode.connect(audioContext.destination);\n                \n                oscillator.frequency.setValueAtTime(392.00, audioContext.currentTime); // G4\n                oscillator.frequency.exponentialRampToValueAtTime(293.66, audioContext.currentTime + 0.5); // D4\n                \n                gainNode.gain.setValueAtTime(0.3, audioContext.currentTime);\n                gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.5);\n                \n                oscillator.start(audioContext.currentTime);\n                oscillator.stop(audioContext.currentTime + 0.5);\n            } catch (e) {\n                console.log(\"音频上下文不支持或已暂停\");\n            }\n        }\n        \n        // 事件监听\n        startBtn.addEventListener('click', startGame);\n        \n        jumpBtn.addEventListener('click', () => {\n            if (gameRunning) {\n                player.jump();\n            } else if (!gameRunning && score === 0) {\n                startGame();\n            }\n        });\n        \n        resetBtn.addEventListener('click', resetGame);\n        \n        restartBtn.addEventListener('click', () => {\n            resetGame();\n            startGame();\n        });\n        \n        mobileJumpBtn.addEventListener('click', () => {\n            if (gameRunning) {\n                player.jump();\n            } else if (!gameRunning && score === 0) {\n                startGame();\n            }\n        });\n        \n        // 键盘控制\n        document.addEventListener('keydown', (e) => {\n            if (e.code === 'Space') {\n                e.preventDefault();\n                if (gameRunning) {\n                    player.jump();\n                } else if (!gameRunning && score === 0) {\n                    startGame();\n                }\n            }\n            \n            if (e.code === 'Enter' && !gameRunning) {\n                if (score === 0) {\n                    startGame();\n                } else {\n                    resetGame();\n                    startGame();\n                }\n            }\n        });\n        \n        // 触摸控制（移动设备）\n        canvas.addEventListener('touchstart', (e) => {\n            e.preventDefault();\n            if (gameRunning) {\n                player.jump();\n            } else if (!gameRunning && score === 0) {\n                startGame();\n            }\n        });\n        \n        // 点击控制（移动设备）\n        canvas.addEventListener('click', (e) => {\n            if (gameRunning) {\n                player.jump();\n            } else if (!gameRunning && score === 0) {\n                startGame();\n            }\n        });\n        \n        // Emoji选择\n        emojiOptions.forEach(option => {\n            option.addEventListener('click', () => {\n                // 移除所有选项的选中状态\n                emojiOptions.forEach(opt => opt.classList.remove('selected'));\n                \n                // 添加当前选项的选中状态\n                option.classList.add('selected');\n                \n                // 更新玩家emoji\n                playerEmoji = option.getAttribute('data-emoji');\n                \n                // 如果游戏未运行，重新绘制玩家\n                if (!gameRunning) {\n                    draw();\n                }\n            });\n        });\n        \n        // 窗口调整大小时调整画布\n        window.addEventListener('resize', () => {\n            // 保持画布尺寸不变，但可以在此添加响应式逻辑\n            // 对于这个简单游戏，我们保持固定尺寸\n        });\n        \n        // 初始提示\n        console.log(\"Emoji跳跃游戏已加载！\");\n        console.log(\"按空格键跳跃，按Enter开始游戏\");\n    </script>\n</body>\n</html>",
